# Shared
MONGODB_HOST_PORT=27019
MONGO_INITDB_ROOT_USERNAME=wc_root
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-strong-password
# Shared Mongo container connection string for backend and router.
MONGODB_URI=mongodb://wc_root:replace-with-a-strong-password@mongo:27019/?authSource=admin
MONGODB_DATABASE=routegate

# Backend (admin/frontend API only)
BACKEND_PORT=3067
BOOTSTRAP_ADMIN_USERNAME=main-admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
BOOTSTRAP_ADMIN_NAME=Main Admin
SESSION_COOKIE_NAME=routegate_session
SESSION_TTL_HOURS=168
SESSION_COOKIE_SECURE=false
NON_ADMIN_BLOCKED_DESTINATION_HOSTS=localhost,127.0.0.1,::1,192.168.1.28

# Router (wildcard ingress)
WILDCARD_BASE_DOMAIN=echosphere.cfd
FRONTEND_ROUTE_SUBDOMAIN=routegate
FRONTEND_ROUTE_DESTINATION=http://frontend:3000

# Frontend
FRONTEND_PORT=3000
BACKEND_API_BASE=http://backend:3067
NEXT_PUBLIC_API_BASE=http://backend:3067
# Optional: add your tunnel host here when running the frontend in dev.
# Example: NEXT_ALLOWED_DEV_ORIGINS=my-tunnel.example.com,*.ngrok-free.app
NEXT_ALLOWED_DEV_ORIGINS=
TERMINAL_TARGET=host
TERMINAL_DOCKER_SERVICE=backend
# Optional terminal overrides:
# TERMINAL_DOCKER_CONTAINER=
# TERMINAL_DOCKER_PROJECT=
# TERMINAL_DOCKER_COMPOSE_DIR=.
# TERMINAL_DOCKER_SHELL=/bin/sh
# TERMINAL_DOCKER_SHELL_ARGS=-l
